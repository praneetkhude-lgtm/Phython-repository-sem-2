set1 = set(map(int,input("Enter elements of first set (space-seprated):").split()))

set2 = set(map(int,input("Enter elements of second set (space-seprated):").split()))

union_set = set1 | set2 

intersection_set = set1 & set2

print("Union of the sets:", union_set)
print("Intersection of ther sets :", intersection_set)

